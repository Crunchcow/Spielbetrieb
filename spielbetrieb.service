[Unit]
Description=FCTM Spielbetrieb Streamlit App
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/spielbetrieb
ExecStart=/var/www/spielbetrieb/.venv/bin/streamlit run app.py --server.port 8505 --server.headless true --server.address 127.0.0.1
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
